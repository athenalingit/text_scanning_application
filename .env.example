# Groq API key for LLM verification step
GROQ_API_KEY=your-groq-api-key-here

# Optional: model used to reconcile PaddleOCR disagreements
# GROQ_RECONCILE_MODEL=qwen/qwen3.6-27b

# Optional: path to Python with PaddleOCR installed (Windows example)
# Use a short path venv if pip fails due to Windows long-path limits:
#   python -m venv C:\paddle-venv
#   C:\paddle-venv\Scripts\pip install -r scripts/requirements.txt
# PYTHON_PATH=C:\paddle-venv\Scripts\python.exe
